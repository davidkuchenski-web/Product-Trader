# Copy to .env for local builds, or set these in your host's dashboard.
# These are baked into the browser bundle at build time — public values only.

# Point the app at a proxy so no Anthropic key is needed in the browser.
# For the bundled Vercel function (app + proxy on the same origin):
VITE_PROXY_URL=/api/claude

# For a Cloudflare Worker instead, use its full URL:
# VITE_PROXY_URL=https://product-love-proxy.<you>.workers.dev

# Optional shared throttle token. Must equal PROXY_TOKEN set on the server.
VITE_PROXY_TOKEN=
